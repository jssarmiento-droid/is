---
// src/components/Footer.astro
---
<footer class="bg-[#7d4e11] text-white py-12 mt-20 border-t-4 border-[#fbbf24]">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-10 text-center md:text-left">
    
    <div>
      <h3 class="text-2xl font-bold italic mb-4">Arepa Don Cuy</h3>
      <p class="text-gray-200 text-sm leading-relaxed">
        Llevando el sabor tradicional a tu mesa con la mejor calidad y frescura.
      </p>
    </div>

    <div>
      <h3 class="text-lg font-bold mb-4 uppercase tracking-widest text-[#fbbf24]">Enlaces</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="/" class="hover:text-yellow-400 transition-colors">Inicio</a></li>
        <li><a href="/menu" class="hover:text-yellow-400 transition-colors">Nuestro Menú</a></li>
        <li><a href="#" class="hover:text-yellow-400 transition-colors">Ubicación</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-lg font-bold mb-4 uppercase tracking-widest text-[#fbbf24]">Síguenos</h3>
      <div class="flex justify-center md:justify-start space-x-4 mb-4">
        <span class="p-2 bg-yellow-600 rounded-full cursor-pointer hover:bg-yellow-500">FB</span>
        <span class="p-2 bg-yellow-600 rounded-full cursor-pointer hover:bg-yellow-500">IG</span>
        <span class="p-2 bg-yellow-600 rounded-full cursor-pointer hover:bg-yellow-500">WA</span>
      </div>
      <p class="text-xs text-gray-400">© 2026 Arepa Don Cuy. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>